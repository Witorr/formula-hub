# Google Gemini AI — usado para gerar/traduzir fórmulas dinamicamente
# Obter em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Conexão Prisma com o banco (PostgreSQL/MySQL/SQLite)
# Exemplo: postgresql://user:password@localhost:5432/formulahub
DATABASE_URL=

# ─── API guard (rate-limit + origin check em /api/generate-operation) ────────

# Origens permitidas (lista separada por vírgula). Em produção é obrigatório
# definir pelo menos uma; em dev, http://localhost:3000 já é aceito.
# Ex.: ALLOWED_ORIGINS="https://formulahub.app,https://www.formulahub.app"
ALLOWED_ORIGINS=

# Alternativa: domínio principal (mesma origem do site).
# Se ALLOWED_ORIGINS não estiver setado, este valor é usado como fallback.
NEXT_PUBLIC_SITE_URL=

# Tuning do token-bucket por IP (opcionais — defaults: 8 / 4 por minuto).
RATE_LIMIT_CAPACITY=
RATE_LIMIT_REFILL_PER_MIN=
